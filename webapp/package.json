        "mattermost-redux": "11.4.0",
        "prop-types": "15.7.2",
        "react": "18.2.0",
        "react-bootstrap": "1.6.7",
        "react-custom-scrollbars-2": "4.5.0",
        "react-dom": "18.2.0",
        "react-redux": "8.1.3",
        "react-select": "5.10.0",
        "redux": "4.2.1",
        "reselect": "4.1.8"
    },
    "overrides": {
        "@types/react": "18.0.38",
        "@types/react-dom": "18.0.11"
    },
    "devDependencies": {
        "ajv": "8.17.1",
        "ajv-keywords": "5.1.0",
